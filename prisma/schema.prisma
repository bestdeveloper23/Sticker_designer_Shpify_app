// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Use PostgreSQL for production (Vercel). For local dev, use DATABASE_URL in .env (e.g. Neon free tier or local Postgres).
// SQLite (file:dev.sqlite) works locally but not on Vercel serverless.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Tracks sticker order count (for 10-order free trial) and usage subscription line item for billing.
model ShopBilling {
  shop                         String   @id
  stickerOrderCount            Int      @default(0)
  usageSubscriptionLineItemId  String?
}
